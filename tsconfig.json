{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "target": "es2017",
    "downlevelIteration": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {"@/*":["src/*"],
    "~/*": ["app/*"]}},
    "include": ["**/*.ts","**/*.tsx","src/types/env.d.ts","nativewind-env.d.ts"],
    "extends": "expo/tsconfig.base"
}
